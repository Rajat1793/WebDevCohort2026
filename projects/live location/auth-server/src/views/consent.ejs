<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GeoLink — Authorize</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@1,700&family=JetBrains+Mono:wght@400;500;700&display=swap" />
  <style>
    :root {
      --primary:#35858e; --primary-dim:#2a6b73; --accent:#7da78c;
      --bg:#090e0f; --surface:#0f1a1b; --surface-2:#162022;
      --border:rgba(53,133,142,0.18); --border-subtle:rgba(255,255,255,0.05);
      --text:#e8f0ec; --text-muted:rgba(200,225,210,0.45); --text-dim:rgba(200,225,210,0.22);
      --font-sans:'Manrope',system-ui,sans-serif;
      --font-serif:'Playfair Display',serif;
      --font-mono:'JetBrains Mono',monospace;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    body {
      font-family: var(--font-sans);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      position: relative;
      -webkit-font-smoothing: antialiased;
    }
    body::before { content:''; position:fixed; inset:0; z-index:0; background:radial-gradient(ellipse 65% 80% at 70% 50%, rgba(53,133,142,0.09) 0%, transparent 70%); }
    body::after { content:''; position:fixed; inset:0; z-index:0; background: repeating-linear-gradient(0deg,transparent,transparent 79px,rgba(53,133,142,0.04) 80px), repeating-linear-gradient(90deg,transparent,transparent 79px,rgba(53,133,142,0.04) 80px); }
    .card { position:relative; z-index:1; width:100%; max-width:400px; background:var(--surface); border:1px solid var(--border); padding:44px; }
    .card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg, var(--primary) 0%, var(--accent) 100%); }
    .card-tag { font-family:var(--font-mono); font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:0.4em; color:var(--primary); margin-bottom:18px; }
    .card-heading { font-family:var(--font-serif); font-size:38px; font-weight:700; line-height:0.9; color:var(--text); margin-bottom:10px; }
    .card-sub { font-size:12px; color:var(--text-muted); line-height:1.6; margin-bottom:28px; }
    .app-name { color:var(--primary); font-weight:700; }
    .permissions { background:var(--surface-2); border:1px solid var(--border-subtle); padding:16px; margin-bottom:24px; }
    .permissions-title { font-family:var(--font-mono); font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:0.3em; color:var(--text-dim); margin-bottom:12px; }
    .permission-item { display:flex; align-items:center; gap:10px; padding:6px 0; font-size:12px; color:var(--text-muted); border-bottom:1px solid var(--border-subtle); }
    .permission-item:last-child { border-bottom:none; }
    .permission-item::before { content:'—'; color:var(--primary); font-family:var(--font-mono); font-weight:700; flex-shrink:0; }
    .actions { display:flex; flex-direction:column; gap:10px; }
    .btn-allow { display:flex; align-items:center; justify-content:center; gap:10px; width:100%; padding:13px; background:var(--primary); color:#fff; border:none; cursor:pointer; font-family:var(--font-mono); font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:0.25em; transition:background 0.15s; }
    .btn-allow:hover { background:var(--primary-dim); }
    .btn-deny { width:100%; padding:12px; background:transparent; color:var(--text-dim); border:1px solid var(--border-subtle); cursor:pointer; font-family:var(--font-mono); font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:0.2em; transition:all 0.15s; text-decoration:none; display:flex; align-items:center; justify-content:center; }
    .btn-deny:hover { border-color:rgba(194,96,90,0.4); color:rgba(194,96,90,0.8); }
    .note { font-family:var(--font-mono); font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:0.2em; color:var(--text-dim); text-align:center; margin-top:18px; }
  </style>
</head>
<body>
  <div class="card">
    <div class="card-tag">GeoLink / Authorization</div>
    <div class="card-heading">Access<br>Request.</div>
    <p class="card-sub">
      <span class="app-name"><%= params.client_id %></span>
      is requesting permission to access your account.
    </p>

    <div class="permissions">
      <div class="permissions-title">Permissions Requested</div>
      <div class="permission-item">Profile — name, username, avatar</div>
      <div class="permission-item">Email — address &amp; verification status</div>
      <div class="permission-item">Identity — persistent user identifier</div>
    </div>

    <div class="actions">
      <form action="/interaction/<%= uid %>/confirm" method="POST">
        <button type="submit" class="btn-allow">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Grant Access
        </button>
      </form>
      <a href="/interaction/<%= uid %>/abort" class="btn-deny">↩ Deny</a>
    </div>

    <p class="note">Access can be revoked by logging out</p>
  </div>
</body>
</html>
