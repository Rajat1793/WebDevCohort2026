<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GeoLink — Access</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@1,700&family=JetBrains+Mono:wght@400;500;700&display=swap" />
  <style>
    :root {
      --primary:       #35858e;
      --primary-dim:   #2a6b73;
      --accent:        #7da78c;
      --bg:            #090e0f;
      --surface:       #0f1a1b;
      --surface-2:     #162022;
      --border:        rgba(53,133,142,0.18);
      --border-subtle: rgba(255,255,255,0.05);
      --text:          #e8f0ec;
      --text-muted:    rgba(200,225,210,0.45);
      --text-dim:      rgba(200,225,210,0.22);
      --danger-bg:     rgba(194,96,90,0.12);
      --danger-border: rgba(194,96,90,0.3);
      --danger-text:   #e07a75;
      --font-sans:  'Manrope', system-ui, sans-serif;
      --font-serif: 'Playfair Display', serif;
      --font-mono:  'JetBrains Mono', monospace;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; font-family: var(--font-sans); background: var(--bg); color: var(--text); -webkit-font-smoothing: antialiased; }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      position: relative;
      overflow: hidden;
    }

    /* grid + glow background */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0;
      background: radial-gradient(ellipse 65% 80% at 70% 50%, rgba(53,133,142,0.09) 0%, transparent 70%);
    }
    body::after {
      content: '';
      position: fixed; inset: 0; z-index: 0;
      background:
        repeating-linear-gradient(0deg, transparent, transparent 79px, rgba(53,133,142,0.04) 80px),
        repeating-linear-gradient(90deg, transparent, transparent 79px, rgba(53,133,142,0.04) 80px);
    }

    .card {
      position: relative; z-index: 1;
      width: 100%; max-width: 400px;
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 48px 44px 44px;
    }
    .card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, var(--primary) 0%, var(--accent) 100%);
    }

    .card-tag {
      font-family: var(--font-mono);
      font-size: 9px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.4em;
      color: var(--primary); margin-bottom: 18px;
    }
    .card-heading {
      font-family: var(--font-serif);
      font-size: 52px; font-weight: 700;
      line-height: 0.9; letter-spacing: -0.02em;
      color: var(--text); margin-bottom: 10px;
    }
    .card-sub {
      font-size: 12px; color: var(--text-muted);
      line-height: 1.6; margin-bottom: 28px;
    }

    /* Tabs */
    .tabs {
      display: flex; gap: 0;
      border: 1px solid var(--border-subtle);
      margin-bottom: 28px;
    }
    .tab {
      flex: 1; padding: 9px;
      border: none; background: transparent;
      font-family: var(--font-mono); font-size: 9px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.25em;
      cursor: pointer; color: var(--text-dim);
      transition: all 0.15s;
    }
    .tab:first-child { border-right: 1px solid var(--border-subtle); }
    .tab.active { background: var(--primary); color: #fff; }
    .tab:not(.active):hover { background: var(--surface-2); color: var(--text-muted); }

    /* Error */
    .error {
      background: var(--danger-bg);
      border: 1px solid var(--danger-border);
      color: var(--danger-text);
      padding: 10px 14px;
      font-family: var(--font-mono); font-size: 9px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.15em;
      margin-bottom: 20px;
    }

    .form { display: flex; flex-direction: column; gap: 16px; }
    .hidden { display: none !important; }

    .field { display: flex; flex-direction: column; gap: 6px; }
    .field-label {
      font-family: var(--font-mono); font-size: 9px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.3em;
      color: var(--text-dim);
    }
    input[type="text"], input[type="email"], input[type="password"] {
      padding: 12px 14px;
      background: var(--surface-2);
      border: 1px solid var(--border-subtle);
      color: var(--text); font-family: var(--font-sans);
      font-size: 13px; font-weight: 500;
      outline: none; transition: border-color 0.15s;
    }
    input::placeholder { color: var(--text-dim); }
    input:focus { border-color: var(--primary); }

    .btn-submit {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      padding: 14px; margin-top: 4px;
      background: var(--primary); color: #fff;
      border: none; cursor: pointer;
      font-family: var(--font-mono); font-size: 10px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.25em;
      transition: background 0.15s, transform 0.1s;
    }
    .btn-submit:hover { background: var(--primary-dim); }
    .btn-submit:active { transform: scale(0.98); }

    .hint {
      margin-top: 24px; padding-top: 20px;
      border-top: 1px solid var(--border-subtle);
    }
    .hint-label {
      font-family: var(--font-mono); font-size: 9px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.25em;
      color: var(--text-dim); margin-bottom: 8px;
    }
    .hint-accounts {
      display: flex; gap: 8px; flex-wrap: wrap;
    }
    .hint-account {
      font-family: var(--font-mono); font-size: 9px; font-weight: 700;
      letter-spacing: 0.1em; color: var(--primary);
      background: rgba(53,133,142,0.1); border: 1px solid var(--border);
      padding: 3px 10px;
    }

    .cancel-link {
      display: block; text-align: center; margin-top: 20px;
      font-family: var(--font-mono); font-size: 9px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.2em;
      color: var(--text-dim); text-decoration: none;
      transition: color 0.15s;
    }
    .cancel-link:hover { color: var(--text-muted); }
  </style>
</head>
<body>
  <div class="card">
    <div class="card-tag">GeoLink / Access</div>
    <div class="card-heading">Live<br>Location.</div>
    <p class="card-sub">Authenticate to join the spatial network.</p>

    <div class="tabs">
      <button class="tab <%= mode === 'login' ? 'active' : '' %>" onclick="switchTab('login')">Sign In</button>
      <button class="tab <%= mode === 'register' ? 'active' : '' %>" onclick="switchTab('register')">Register</button>
    </div>

    <% if (error) { %>
      <div class="error">/ <%= error %></div>
    <% } %>

    <!-- Login Form -->
    <form id="loginForm"
          class="form <%= mode === 'login' ? '' : 'hidden' %>"
          action="/interaction/<%= uid %>/login"
          method="POST">
      <div class="field">
        <label class="field-label" for="username">01 / Identity</label>
        <input type="text" id="username" name="username"
               placeholder="alice" autocomplete="username" autofocus required />
      </div>
      <div class="field">
        <label class="field-label" for="password">02 / Key</label>
        <input type="password" id="password" name="password"
               placeholder="••••••••" autocomplete="current-password" required />
      </div>
      <button type="submit" class="btn-submit">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        Initialize Session
      </button>
    </form>

    <!-- Register Form -->
    <form id="registerForm"
          class="form <%= mode === 'register' ? '' : 'hidden' %>"
          action="/interaction/<%= uid %>/register"
          method="POST">
      <div class="field">
        <label class="field-label" for="regName">01 / Full Name</label>
        <input type="text" id="regName" name="name" placeholder="Alice Smith" />
      </div>
      <div class="field">
        <label class="field-label" for="regUsername">02 / Username</label>
        <input type="text" id="regUsername" name="username"
               placeholder="alice" autocomplete="username" required />
      </div>
      <div class="field">
        <label class="field-label" for="regEmail">03 / Email</label>
        <input type="email" id="regEmail" name="email"
               placeholder="alice@example.com" required />
      </div>
      <div class="field">
        <label class="field-label" for="regPassword">04 / Key <span style="color:var(--text-dim);font-weight:400;letter-spacing:0">(min. 6 chars)</span></label>
        <input type="password" id="regPassword" name="password"
               placeholder="••••••••" autocomplete="new-password" minlength="6" required />
      </div>
      <button type="submit" class="btn-submit">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
        Create Account
      </button>
    </form>

    <div class="hint">
      <div class="hint-label">Demo Account · username: demo · pw: demo</div>
      <div class="hint-accounts">
        <span class="hint-account">demo</span>
      </div>
    </div>

    <a class="cancel-link" href="/interaction/<%= uid %>/abort">↩ Cancel</a>
  </div>

  <script>
    function switchTab(mode) {
      var loginForm    = document.getElementById('loginForm');
      var registerForm = document.getElementById('registerForm');
      var tabs         = document.querySelectorAll('.tab');
      if (mode === 'login') {
        loginForm.classList.remove('hidden');
        registerForm.classList.add('hidden');
        tabs[0].classList.add('active');
        tabs[1].classList.remove('active');
      } else {
        loginForm.classList.add('hidden');
        registerForm.classList.remove('hidden');
        tabs[0].classList.remove('active');
        tabs[1].classList.add('active');
      }
    }
  </script>
</body>
</html>
