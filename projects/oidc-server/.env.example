# OIDC Server — Environment Variables

PORT=4000
NODE_ENV=development
ISSUER=http://localhost:4000

# Secret used to sign OIDC session cookies
COOKIE_SECRET=change-this-cookie-secret-min-32-chars

# Optional: path to a custom clients config JSON (overrides config/clients.json)
# CLIENTS_FILE=./config/clients.json

# Optional: path to a custom users file (overrides config/users.json)
# USERS_FILE=./config/users.json
